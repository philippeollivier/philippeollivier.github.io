  },
  {
    id: 'may3',
    label: 'May 3',
    date: 'Saturday, May 3',
    title: 'Bikes, Wine & Departure',
    subtitle: 'Final Queenstown adventure',
    items: [
      { type: 'activity', time: 'Afternoon', title: 'Bike + Wine tour', detail: 'Pedal through Queenstown vineyards, tastings', cost: '$121 NZD per person' },
      { type: 'flight', time: 'Evening', title: 'Fly back to Auckland', detail: 'Queenstown (ZQN) → Auckland (AKL)', cost: '$150 NZD per person', mapsQuery: 'Queenstown Airport, Queenstown, New Zealand' },
      { type: 'activity', time: 'Night', title: 'Final night in Auckland', detail: 'Last-minute shopping, city walk, dinner' }
    ]
  },
  {
    id: 'may4',
    label: 'May 4',
    date: 'Sunday, May 4',
    title: 'Departures',
    subtitle: 'Safe travels home!',
    items: [
      { type: 'flight', time: '1:00 PM', title: 'Kevin Xiang departs', detail: 'Flight DL0064 from Auckland', mapsQuery: 'Auckland Airport, Auckland, New Zealand' },
      { type: 'flight', time: '1:50 PM', title: 'Evan Liu & Yang Lowe depart', detail: 'Flights TBD / UA336 from Auckland' },
      { type: 'flight', time: '7:25 PM', title: 'Philippe & Erica & Matthew depart', detail: 'Flight NZ2 from Auckland' },
      { type: 'flight', time: '7:50 PM', title: 'David Song departs', detail: 'Flight NZ8 from Auckland' },
      { type: 'flight', time: '8:00 PM', title: 'Adriene Tien departs', detail: 'Flight NZ4752 from Auckland' }
    ]
