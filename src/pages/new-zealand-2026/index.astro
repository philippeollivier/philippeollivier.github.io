---
// NZ Trip 2026 - Refined Travel Itinerary
// Inspired by sophisticated design patterns from travel planning experiences
// Apr 27 - May 4, 2026 | 8 friends, 8 days

type ItemType = 'flight' | 'transport' | 'hike' | 'hotel' | 'activity' | 'meal' | 'info';

interface TimelineItem {
  type: ItemType;
  time?: string;
  title: string;
  detail?: string;
  cost?: string;
  mapsQuery?: string;
  link?: string;
}

interface Day {
  id: string;
  label: string;
  date: string;
  title: string;
  subtitle?: string;
  items: TimelineItem[];
}

