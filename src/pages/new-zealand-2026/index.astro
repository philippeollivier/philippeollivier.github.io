interface Hotel { name: string; address: string; dates: string; link?: string; }
interface EmergencyContact { label: string; number: string; detail?: string; }
interface NZPhrase { maori: string; english: string; }

const hotels: Hotel[] = [
  { name: 'Lylo Pod Hostel', address: '36 Man Street, Queenstown 9300 NZ', dates: 'Apr 28–29', link: 'https://www.lylo.com/queenstown/rooms-pods/pods-room/' }
];

const emergencyContacts: EmergencyContact[] = [
  { label: 'Emergency (Police/Fire/Ambulance)', number: '111' },
  { label: 'Non-emergency Police', number: '105' },
  { label: 'DOC Backcountry Emergency', number: '0800 362 468' }
];

const nzPhrases: NZPhrase[] = [
  { maori: 'Kia ora', english: 'Hello' },
  { maori: 'Ka pai', english: 'Good job' },
  { maori: 'Haere rā', english: 'Goodbye' },
  { maori: 'Sweet as', english: 'Awesome' },
  { maori: 'Chur', english: 'Thanks / Cool' },
  { maori: 'Tramping', english: 'Hiking' },
  { maori: 'Jandals', english: 'Flip-flops' },
  { maori: 'Yeah nah', english: 'No' },
  { maori: 'Nah yeah', english: 'Yes' }
];

function getTypeIcon(type: ItemType): string {
  const icons: Record<ItemType, string> = {
    flight: '✈️', transport: '🚌', hike: '🥾', hotel: '🏨',
    activity: '🎯', meal: '🍴', info: 'ℹ️'
  };
  return icons[type];
}

function generateMapsLink(query: string): string {
  return `https://maps.google.com/?q=${encodeURIComponent(query)}`;
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>New Zealand 2026 | Apr 27 – May 4</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@400;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      /* NZ-inspired color palette */
      --color-cream: #faf9f7;
      --color-forest: #1b3d2d;
      --color-ocean: #0d5b6e;
      --color-sky: #7ea8c4;
      --color-gold: #c9a961;
      --color-earth: #a87a56;
      --color-leaf: #5ba582;
      --color-accent: #d4746f;

      /* Category colors */
      --color-flight: #0d5b6e;
      --color-transport: #5ba582;
      --color-hike: #2d6a4f;
      --color-hotel: #7ea8c4;
      --color-activity: #c9a961;
      --color-meal: #d4746f;
      --color-info: #9b8b7e;

      /* Neutral palette */
      --color-bg: #faf9f7;
      --color-text: #1a1a1a;
      --color-text-muted: #6b6b6b;
      --color-border: #e8e7e5;
      --color-card-bg: #fff9f7;

      --font-heading: 'Noto Serif JP', serif;
      --font-body: 'Inter', sans-serif;
      --radius-sm: 0.5rem;
      --radius-md: 0.75rem;
      --radius-lg: 1rem;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
      font-family: var(--font-body);
      background-color: var(--color-bg);
      color: var(--color-text);
    }

    body {
      line-height: 1.6;
      overflow: auto !important;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    /* Typography */
    h1, h2, h3 { font-family: var(--font-heading); font-weight: 600; letter-spacing: -0.01em; }
    h1 { font-size: 2.75rem; line-height: 1.1; margin-bottom: 0.75rem; }
    h2 { font-size: 1.875rem; margin-bottom: 0.5rem; }
    h3 { font-size: 1.25rem; margin-bottom: 0.5rem; }
    p { color: var(--color-text); }

    /* Petal animation */
    @keyframes petalFall {
      0% { transform: translateY(-5vh) rotate(0) rotate3d(1, 0.5, 0, 0); opacity: 0.8; }
      to { transform: translateY(105vh) rotate(360deg) rotate3d(1, 0.5, 0, 720deg); opacity: 0; }
    }

    @keyframes petalSway {
      0%, to { transform: translateX(0); }
      25% { transform: translateX(20px); }
      75% { transform: translateX(-15px); }
    }

    .petal {
      pointer-events: none;
      position: absolute;
      opacity: 0.6;
      animation: petalFall linear infinite;
      will-change: transform;
    }

    .petal-inner {
      width: 12px;
      height: 16px;
      animation: petalSway ease-in-out infinite;
      background: linear-gradient(135deg, #2d6a4f, #5ba582);
      border-radius: 50% 0;
      opacity: 0.7;
    }

    /* Sticky Navigation */
    nav.sticky {
      position: sticky;
      top: 0;
      z-index: 40;
      background: rgba(250, 249, 247, 0.95);
      backdrop-filter: blur(8px);
      border-bottom: 1px solid var(--color-border);
      padding: 1rem 0;
    }

    .nav-container {
      max-width: 100%;
      overflow-x: auto;
      overflow-y: hidden;
      -webkit-overflow-scrolling: touch;
      padding: 0 1.5rem;
    }

    .nav-tabs {
      display: flex;
      gap: 0.75rem;
      list-style: none;
      white-space: nowrap;
      min-width: fit-content;
    }

    .nav-btn {
      padding: 0.5rem 1.25rem;
      border: 1.5px solid var(--color-border);
      background: white;
      color: var(--color-text-muted);
      border-radius: var(--radius-sm);
      cursor: pointer;
      font-size: 0.875rem;
      font-weight: 500;
      font-family: var(--font-body);
      transition: all 0.3s ease;
      flex-shrink: 0;
    }

    .nav-btn:hover {
      border-color: var(--color-forest);
      color: var(--color-forest);
    }

    .nav-btn.active {
      background: var(--color-forest);
      color: white;
      border-color: var(--color-forest);
    }

    /* Hero Section */
    .hero {
      background: linear-gradient(135deg, var(--color-forest) 0%, var(--color-ocean) 100%);
      color: white;
      padding: 4rem 1.5rem 5rem;
      text-align: center;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .hero h1 {
      font-size: 3.5rem;
      margin-bottom: 0.5rem;
      opacity: 0.98;
      letter-spacing: -0.02em;
    }

    .hero-dates {
      font-size: 1.125rem;
      opacity: 0.9;
      margin-bottom: 1rem;
    }

    .hero-tagline {
      font-size: 0.95rem;
      opacity: 0.85;
      font-weight: 300;
    }

    /* Container */
    .container {
      max-width: 800px;
      margin: 0 auto;
      padding: 3rem 1.5rem;
    }

    /* Day sections */
    .day-section {
      margin-bottom: 3.5rem;
      scroll-margin-top: 90px;
      opacity: 0;
      animation: fadeInUp 0.6s ease forwards;
    }

    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .day-section:nth-child(1) { animation-delay: 0.1s; }
    .day-section:nth-child(2) { animation-delay: 0.15s; }
    .day-section:nth-child(3) { animation-delay: 0.2s; }
    .day-section:nth-child(4) { animation-delay: 0.25s; }
    .day-section:nth-child(5) { animation-delay: 0.3s; }
    .day-section:nth-child(6) { animation-delay: 0.35s; }
    .day-section:nth-child(7) { animation-delay: 0.4s; }
    .day-section:nth-child(8) { animation-delay: 0.45s; }

    .day-header {
      margin-bottom: 2rem;
      padding-bottom: 1.5rem;
      border-bottom: 2px solid var(--color-leaf);
    }

    .day-date {
      font-size: 0.875rem;
      color: var(--color-text-muted);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 0.5rem;
      font-weight: 500;
    }

    .day-title {
      font-size: 2rem;
      color: var(--color-forest);
      margin-bottom: 0.25rem;
    }

    .day-subtitle {
      font-size: 1rem;
      color: var(--color-text-muted);
      font-weight: 300;
    }

    /* Timeline */
    .timeline {
      position: relative;
      padding-left: 3rem;
    }

    .timeline::before {
      content: '';
      position: absolute;
      left: 8px;
      top: 0;
      bottom: 0;
      width: 2px;
      background: linear-gradient(to bottom, var(--color-leaf), var(--color-border));
    }

    .timeline-item {
      position: relative;
      margin-bottom: 1.5rem;
    }

    .timeline-dot {
      position: absolute;
      left: -29px;
      top: 8px;
      width: 16px;
      height: 16px;
      border-radius: 50%;
      border: 3px solid white;
      background: var(--color-leaf);
      z-index: 2;
      transition: all 0.3s ease;
    }

    .timeline-item.flight .timeline-dot { background: var(--color-flight); }
    .timeline-item.transport .timeline-dot { background: var(--color-transport); }
    .timeline-item.hike .timeline-dot { background: var(--color-hike); }
    .timeline-item.hotel .timeline-dot { background: var(--color-hotel); }
    .timeline-item.activity .timeline-dot { background: var(--color-activity); }
    .timeline-item.meal .timeline-dot { background: var(--color-meal); }
    .timeline-item.info .timeline-dot { background: var(--color-info); }

    .timeline-content {
      padding: 1.25rem;
      background: var(--color-card-bg);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      border-left: 4px solid var(--color-leaf);
      transition: all 0.3s ease;
      animation: slideIn 0.4s ease;
    }

    @keyframes slideIn {
      from {
        opacity: 0;
        transform: translateX(-10px);
      }
      to {
        opacity: 1;
        transform: translateX(0);
      }
    }

    .timeline-item.flight .timeline-content { border-left-color: var(--color-flight); }
    .timeline-item.transport .timeline-content { border-left-color: var(--color-transport); }
    .timeline-item.hike .timeline-content { border-left-color: var(--color-hike); }
    .timeline-item.hotel .timeline-content { border-left-color: var(--color-hotel); }
    .timeline-item.activity .timeline-content { border-left-color: var(--color-activity); }
    .timeline-item.meal .timeline-content { border-left-color: var(--color-meal); }
    .timeline-item.info .timeline-content { border-left-color: var(--color-info); }

    .timeline-content:hover {
      border-color: var(--color-forest);
      box-shadow: 0 4px 12px rgba(27, 61, 45, 0.08);
      transform: translateY(-2px);
    }

    .timeline-time {
      font-size: 0.8rem;
      font-weight: 600;
      color: var(--color-flight);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      margin-bottom: 0.5rem;
    }

    .timeline-item.transport .timeline-time { color: var(--color-transport); }
    .timeline-item.hike .timeline-time { color: var(--color-hike); }
    .timeline-item.hotel .timeline-time { color: var(--color-hotel); }
    .timeline-item.activity .timeline-time { color: var(--color-activity); }
    .timeline-item.meal .timeline-time { color: var(--color-meal); }
    .timeline-item.info .timeline-time { color: var(--color-info); }

    .timeline-title {
      font-size: 1.05rem;
      font-weight: 600;
      margin-bottom: 0.35rem;
      color: var(--color-text);
    }

    .timeline-detail {
      font-size: 0.95rem;
      color: var(--color-text-muted);
      line-height: 1.5;
    }

    .timeline-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem;
      margin-top: 0.75rem;
      font-size: 0.875rem;
    }

    .meta-badge {
      display: inline-block;
      padding: 0.35rem 0.75rem;
      background: rgba(45, 106, 79, 0.08);
      color: var(--color-forest);
      border-radius: 999px;
      font-weight: 500;
    }

    /* Links and buttons */
    a {
      color: var(--color-forest);
      text-decoration: none;
      transition: color 0.3s ease;
    }

    a:hover {
      color: var(--color-ocean);
      text-decoration: underline;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.45rem 0.9rem;
      background: var(--color-forest);
      color: white;
      border: none;
      border-radius: var(--radius-sm);
      cursor: pointer;
      font-size: 0.875rem;
      font-weight: 500;
      font-family: var(--font-body);
      transition: all 0.2s ease;
      text-decoration: none;
    }

    .btn:hover {
      background: var(--color-ocean);
      transform: translateY(-1px);
      box-shadow: 0 4px 8px rgba(27, 61, 45, 0.15);
    }

    .btn-copy {
      background: var(--color-text-muted);
    }

    .btn-copy:hover {
      background: var(--color-forest);
    }

    /* Quick Reference Section */
    .reference-section {
      background: white;
      border: 1px solid var(--color-border);
      border-radius: var(--radius-lg);
      padding: 3rem;
      margin-top: 4rem;
      animation: fadeInUp 0.6s ease 0.5s forwards;
      opacity: 0;
    }

    .reference-section h3 {
      color: var(--color-forest);
      margin-bottom: 2rem;
      padding-bottom: 1rem;
      border-bottom: 2px solid var(--color-leaf);
      font-size: 1.5rem;
    }

    .reference-subsection {
      margin-bottom: 3rem;
    }

    .reference-subsection:last-child {
      margin-bottom: 0;
    }

    .reference-title {
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--color-forest);
      margin-bottom: 1.25rem;
    }

    /* Hotel cards */
    .hotel-card {
      padding: 1.5rem;
      background: var(--color-card-bg);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      border-left: 4px solid var(--color-hotel);
      margin-bottom: 1rem;
      transition: all 0.3s ease;
    }

    .hotel-card:hover {
      border-color: var(--color-hotel);
      box-shadow: 0 4px 12px rgba(126, 168, 196, 0.1);
    }

    .hotel-name {
      font-weight: 700;
      font-size: 1.1rem;
      margin-bottom: 0.5rem;
      color: var(--color-forest);
    }

    .hotel-info {
      font-size: 0.95rem;
      color: var(--color-text-muted);
      margin-bottom: 0.35rem;
    }

    /* Emergency cards */
    .emergency-card {
      padding: 1.5rem;
      background: linear-gradient(135deg, #f8ecec, #fce8e8);
      border: 1px solid #f5d5d5;
      border-left: 4px solid #d4746f;
      border-radius: var(--radius-md);
      margin-bottom: 1rem;
    }

    .emergency-label {
      font-weight: 600;
      color: #a87a56;
      margin-bottom: 0.35rem;
      font-size: 0.9rem;
    }

    .emergency-number {
      font-size: 2rem;
      font-weight: 700;
      color: #d4746f;
      font-family: var(--font-body);
      letter-spacing: 0.05em;
    }

    /* Phrase cards */
    .phrase-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1rem;
    }

    .phrase-card {
      padding: 1.25rem;
      background: linear-gradient(135deg, #f0f6f3, #e8f2ed);
      border: 1px solid #d4e8e0;
      border-radius: var(--radius-md);
      transition: all 0.3s ease;
    }

    .phrase-card:hover {
      border-color: var(--color-leaf);
      box-shadow: 0 4px 12px rgba(91, 165, 130, 0.1);
      transform: translateY(-2px);
    }

    .phrase-maori {
      font-weight: 700;
      color: var(--color-leaf);
      margin-bottom: 0.35rem;
      font-size: 1.05rem;
    }

    .phrase-english {
      font-size: 0.9rem;
      color: var(--color-text-muted);
    }

    /* Footer */
    footer {
      text-align: center;
      padding: 3rem;
      color: var(--color-text-muted);
      border-top: 1px solid var(--color-border);
      margin-top: 3rem;
      font-size: 0.95rem;
    }

    /* Responsive */
    @media (max-width: 640px) {
      .hero h1 { font-size: 2.25rem; }
      .container { padding: 2rem 1rem; }
      .reference-section { padding: 2rem; }
      .timeline { padding-left: 2.5rem; }
      .timeline-dot { left: -25px; }
      .phrase-grid { grid-template-columns: 1fr; }
      .day-title { font-size: 1.5rem; }
    }
  </style>
</head>
<body>
  <!-- Petals animation -->
  <div style="position: fixed; inset: 0; pointer-events: none; z-index: 0; overflow: hidden;">
    <script>
      for (let i = 0; i < 4; i++) {
        const petal = document.createElement('div');
        petal.className = 'petal';
        petal.style.left = Math.random() * 100 + '%';
        petal.style.animationDuration = (3 + Math.random() * 2) + 's';
        petal.style.animationDelay = Math.random() * 2 + 's';
        const inner = document.createElement('div');
        inner.className = 'petal-inner';
        petal.appendChild(inner);
        document.body.querySelector('[style*="position: fixed"]')?.appendChild(petal);
      }
    </script>
  </div>

  <!-- Sticky Navigation -->
  <nav class="sticky">
    <div class="nav-container">
      <ul class="nav-tabs">
        {days.map((day) => (
          <li>
            <button
              class="nav-btn"
              data-anchor={day.id}
              onclick={`document.getElementById('${day.id}').scrollIntoView(); updateNav('${day.id}')`}
            >
              {day.label}
            </button>
          </li>
        ))}
        <li>
          <button class="nav-btn" data-anchor="info" onclick="document.getElementById('info').scrollIntoView(); updateNav('info')">
            Info
          </button>
        </li>
      </ul>
    </div>
  </nav>

  <!-- Hero -->
  <section class="hero">
    <h1>New Zealand 2026</h1>
    <p class="hero-dates">April 27 – May 4</p>
    <p class="hero-tagline">8 friends · 8 days · unforgettable memories</p>
  </section>

  <!-- Main Content -->
  <div class="container">
    {days.map((day) => (
      <section class="day-section" id={day.id}>
        <div class="day-header">
          <div class="day-date">{day.date}</div>
          <h2 class="day-title">{day.title}</h2>
          {day.subtitle && <p class="day-subtitle">{day.subtitle}</p>}
        </div>

        <div class="timeline">
          {day.items.map((item) => (
            <div class={`timeline-item ${item.type}`}>
              <div class="timeline-dot"></div>
              <div class="timeline-content">
                {item.time && <div class="timeline-time">{item.time}</div>}
                <div class="timeline-title">{getTypeIcon(item.type)} {item.title}</div>
                {item.detail && <div class="timeline-detail">{item.detail}</div>}
                {(item.cost || item.mapsQuery || item.link) && (
                  <div class="timeline-meta">
                    {item.cost && <span class="meta-badge">💰 {item.cost}</span>}
                    {item.mapsQuery && (
                      <a href={generateMapsLink(item.mapsQuery)} target="_blank" rel="noopener" class="btn">
                        📍 Maps
                      </a>
                    )}
                    {item.link && (
                      <a href={item.link} target="_blank" rel="noopener" class="btn">
                        🔗 Link
                      </a>
                    )}
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </section>
    ))}

    <!-- Quick Reference -->
    <section class="reference-section" id="info">
      <h3>✨ Quick Reference</h3>

      <!-- Hotels -->
      <div class="reference-subsection">
        <div class="reference-title">🏨 Accommodations</div>
        {hotels.map((hotel) => (
          <div class="hotel-card">
            <div class="hotel-name">{hotel.name}</div>
            <div class="hotel-info">📍 {hotel.address}</div>
            <div class="hotel-info">📅 {hotel.dates}</div>
            <div style="margin-top: 0.75rem;">
              <button class="btn btn-copy" onclick={`navigator.clipboard.writeText('${hotel.address}'); alert('Copied!')`}>
                📋 Copy Address
              </button>
              {hotel.link && (
                <a href={hotel.link} target="_blank" rel="noopener" class="btn" style="margin-left: 0.5rem;">
                  🔗 Website
                </a>
              )}
            </div>
          </div>
        ))}
      </div>

      <!-- Emergency -->
      <div class="reference-subsection">
        <div class="reference-title">🚨 Emergency Contacts</div>
        {emergencyContacts.map((contact) => (
          <div class="emergency-card">
            <div class="emergency-label">{contact.label}</div>
            <div class="emergency-number">{contact.number}</div>
            {contact.detail && <div style="font-size: 0.85rem; color: #a87a56; margin-top: 0.35rem;">{contact.detail}</div>}
          </div>
        ))}
      </div>

      <!-- Phrases -->
      <div class="reference-subsection">
        <div class="reference-title">🗣️ Te Reo Māori & NZ Slang</div>
        <div class="phrase-grid">
          {nzPhrases.map((phrase) => (
            <div class="phrase-card">
              <div class="phrase-maori">{phrase.maori}</div>
              <div class="phrase-english">{phrase.english}</div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </div>

  <!-- Footer -->
  <footer>
    <p>Safe travels! 🥾 Kia ora | Made for the crew, 2026</p>
  </footer>

  <script>
    function updateNav(id) {
      document.querySelectorAll('.nav-btn').forEach(btn => btn.classList.remove('active'));
      document.querySelector(`[data-anchor="${id}"]`)?.classList.add('active');
    }

    window.addEventListener('scroll', () => {
      const sections = document.querySelectorAll('[id]');
      let current = '';
      sections.forEach(section => {
        if (window.scrollY >= section.offsetTop - 100) {
          current = section.id;
        }
      });
      if (current) updateNav(current);
    });

    updateNav('apr27');
  </script>
</body>
</html>
