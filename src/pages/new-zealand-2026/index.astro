    title: 'Routeburn Track: Day 1',
    subtitle: '7.5 km to first campsite',
    items: [
      { type: 'activity', time: 'Morning', title: 'Pick up rental camping gear', detail: 'Tent, sleeping bag, mat, cookware', cost: '$50–100 NZD per day', mapsQuery: 'Queenstown, New Zealand', link: 'https://smallplanetsports.com/rentals/camp-and-hike/' },
      { type: 'transport', time: '11:15 AM', title: 'Bus to Routeburn Shelter', detail: 'Queenstown → The Divide', cost: '$155 NZD per person (includes return)', mapsQuery: 'Routeburn Shelter, Glenorchy, New Zealand', link: 'https://www.tracknet.net/' },
      { type: 'hike', time: '~1:00 PM', title: 'Hike to Routeburn Flats Campsite', detail: 'Distance: 7.5 km | Duration: 1.5–2.5 hrs', mapsQuery: 'Routeburn Flats Campsite, New Zealand', link: 'https://www.doc.govt.nz/parks-and-recreation/places-to-go/fiordland/places/fiordland-national-park/things-to-do/tracks/routeburn-track/' },
