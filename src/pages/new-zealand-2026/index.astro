// Helper function to get color classes by type
function getTypeColor(type: ItemType): string {
  const colors: Record<ItemType, string> = {
    flight: 'border-blue-500 bg-blue-50 dark:bg-blue-900/20',
    transport: 'border-indigo-500 bg-indigo-50 dark:bg-indigo-900/20',
    hike: 'border-green-600 bg-green-50 dark:bg-green-900/20',
    hotel: 'border-cyan-500 bg-cyan-50 dark:bg-cyan-900/20',
    activity: 'border-orange-500 bg-orange-50 dark:bg-orange-900/20',
    meal: 'border-amber-500 bg-amber-50 dark:bg-amber-900/20',
    info: 'border-gray-400 bg-gray-50 dark:bg-gray-900/20',
    note: 'border-purple-500 bg-purple-50 dark:bg-purple-900/20'
  };
  return colors[type];
}

function getTypeIcon(type: ItemType): string {
  const icons: Record<ItemType, string> = {
    flight: '✈️',
    transport: '🚌',
    hike: '🥾',
    hotel: '🏨',
    activity: '🎯',
    meal: '🍴',
    info: 'ℹ️',
    note: '📝'
  };
  return icons[type];
}

function generateMapsLink(query: string): string {
  return `https://maps.google.com/?q=${encodeURIComponent(query)}`;
}

function copyToClipboard(text: string) {
  navigator.clipboard.writeText(text).then(() => {
    alert('Copied: ' + text);
  });
}
