// Standalone page: unique fonts (Fraunces + Outfit), NZ-inspired palette

type ItemType = 'flight' | 'transport' | 'hike' | 'hotel' | 'activity' | 'meal' | 'info';

interface TimelineItem {
  type: ItemType;
  time?: string;
  title: string;
  detail?: string;
  cost?: string;
  distance?: string;
  mapsQuery?: string;
  link?: string;
  flightCodes?: string[];
}

interface Day {
  id: string;
  label: string;
  dayNum: string;
  date: string;
  title: string;
  subtitle?: string;
  noSignal?: boolean;
  items: TimelineItem[];
}

interface Hotel {
  name: string;
  address: string;
  dates: string;
  mapsQuery: string;
  link?: string;
}

interface EmergencyContact {
  label: string;
  number: string;
  detail?: string;
}

interface Phrase {
  term: string;
  meaning: string;
  isMaori?: boolean;
}

interface CostItem {
  label: string;
  amount: string;
  usd: string;
}

