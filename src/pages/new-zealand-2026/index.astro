  title: string;
  detail?: string;
  cost?: string;
  mapsQuery?: string;
  link?: string;
}

interface Day {
  id: string;
  label: string;
  dayNum: string;
  date: string;
  title: string;
  subtitle?: string;
  items: TimelineItem[];
}

interface Hotel {
  name: string;
  address: string;
  dates: string;
  mapsQuery: string;
  link?: string;
}

interface EmergencyContact {
  label: string;
  number: string;
  detail?: string;
}

interface Phrase {
  term: string;
  meaning: string;
  isMaori?: boolean;
}

interface CostItem {
  label: string;
  amount: string;
}

