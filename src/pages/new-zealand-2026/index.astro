      { type: 'hike', time: '~9:00 AM', title: 'Hike to The Divide (park exit)', detail: 'Distance: 12 km | Duration: 4–5.5 hrs | Mostly downhill', mapsQuery: 'The Divide, Fiordland, New Zealand' },
