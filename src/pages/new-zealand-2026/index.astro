      color: #b45309;
    }

    @media (prefers-color-scheme: dark) {
      .timeline-item.activity .meta-badge {
        color: #fed7aa;
      }
    }

    .timeline-item.meal .meta-badge {
      background: rgba(234, 179, 8, 0.1);
      color: #854d0e;
    }

    @media (prefers-color-scheme: dark) {
      .timeline-item.meal .meta-badge {
        color: #fef08a;
      }
    }

    /* Links and buttons */
    a {
      color: #10b981;
      text-decoration: none;
      font-weight: 500;
      transition: color 0.2s ease;
    }

    a:hover {
      color: #059669;
      text-decoration: underline;
    }

    @media (prefers-color-scheme: dark) {
      a {
        color: #6ee7b7;
      }
      a:hover {
        color: #a7f3d0;
      }
    }

    button {
      font-family: inherit;
    }

    .btn-maps, .btn-copy {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0.4rem 0.8rem;
      font-size: 0.875rem;
      font-weight: 500;
      background: #10b981;
      color: white;
      border: none;
      border-radius: 0.375rem;
      cursor: pointer;
      transition: all 0.2s ease;
      margin-right: 0.5rem;
      margin-top: 0.5rem;
    }

    .btn-maps:hover, .btn-copy:hover {
      background: #059669;
      transform: translateY(-1px);
      box-shadow: 0 2px 4px rgba(16, 185, 129, 0.3);
    }

    .btn-copy {
      background: #6b7280;
    }

    .btn-copy:hover {
      background: #4b5563;
    }

    /* Quick Reference */
    .reference-section {
      background: white;
      border: 2px solid #e5e7eb;
      border-radius: 0.75rem;
      padding: 2rem;
      margin-top: 3rem;
      margin-bottom: 2rem;
    }

    @media (prefers-color-scheme: dark) {
      .reference-section {
        background: #1f2937;
        border-color: #374151;
      }
    }

    .reference-section h3 {
      color: #065f46;
      margin-bottom: 1.5rem;
      border-bottom: 2px solid #10b981;
      padding-bottom: 0.75rem;
    }

    @media (prefers-color-scheme: dark) {
      .reference-section h3 {
        color: #6ee7b7;
      }
    }

    .hotels-grid {
      display: grid;
      gap: 1.5rem;
      margin-bottom: 2rem;
    }

    .hotel-card {
      padding: 1.5rem;
      background: #f3f4f6;
      border: 2px solid #d1d5db;
      border-radius: 0.5rem;
      border-left: 4px solid #06b6d4;
    }

    @media (prefers-color-scheme: dark) {
      .hotel-card {
        background: #111827;
        border-color: #4b5563;
      }
    }

    .hotel-name {
      font-weight: 600;
      font-size: 1.1rem;
      margin-bottom: 0.5rem;
    }

    .hotel-detail {
      font-size: 0.95rem;
      color: #6b7280;
      margin-bottom: 0.5rem;
    }

    @media (prefers-color-scheme: dark) {
      .hotel-detail {
        color: #d1d5db;
      }
    }

    .emergency-grid {
      display: grid;
      gap: 1rem;
      margin-bottom: 2rem;
    }

    .emergency-item {
      padding: 1rem;
      background: #fef2f2;
      border: 2px solid #fecaca;
      border-radius: 0.5rem;
      border-left: 4px solid #ef4444;
    }

    @media (prefers-color-scheme: dark) {
      .emergency-item {
        background: #7f1d1d;
        border-color: #991b1b;
      }
    }

    .emergency-label {
      font-weight: 600;
      color: #7f1d1d;
      margin-bottom: 0.25rem;
    }

    @media (prefers-color-scheme: dark) {
      .emergency-label {
        color: #fca5a5;
      }
    }

    .emergency-number {
      font-size: 1.5rem;
      font-weight: 700;
      color: #dc2626;
      font-family: 'Monaco', 'Menlo', monospace;
    }

    @media (prefers-color-scheme: dark) {
      .emergency-number {
        color: #fca5a5;
      }
    }

    .emergency-detail {
      font-size: 0.85rem;
      color: #6b7280;
      margin-top: 0.25rem;
    }

    @media (prefers-color-scheme: dark) {
      .emergency-detail {
        color: #d1d5db;
      }
    }

    .phrases-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 1rem;
    }

    .phrase-card {
      padding: 1rem;
      background: #f0fdf4;
      border: 2px solid #bbf7d0;
      border-radius: 0.5rem;
      border-left: 4px solid #22c55e;
    }

    @media (prefers-color-scheme: dark) {
      .phrase-card {
        background: #064e3b;
        border-color: #10b981;
      }
    }

    .phrase-maori {
      font-weight: 600;
      font-size: 1.05rem;
      color: #15803d;
      margin-bottom: 0.25rem;
    }

    @media (prefers-color-scheme: dark) {
      .phrase-maori {
        color: #86efac;
      }
    }

    .phrase-english {
      font-size: 0.95rem;
      color: #6b7280;
    }

    @media (prefers-color-scheme: dark) {
      .phrase-english {
        color: #d1d5db;
      }
    }

    /* Footer */
    footer {
      text-align: center;
      padding: 2rem;
      color: #6b7280;
      border-top: 1px solid #e5e7eb;
      margin-top: 3rem;
    }

    @media (prefers-color-scheme: dark) {
      footer {
        border-top-color: #374151;
        color: #9ca3af;
      }
    }

    /* Mobile responsiveness */
    @media (max-width: 640px) {
      h1 {
        font-size: 1.875rem;
      }

      h2 {
        font-size: 1.5rem;
      }

      .hero {
        padding: 2rem 1rem;
      }

      .hero h1 {
        font-size: 2rem;
      }

      .container {
        padding: 1.5rem 0.75rem;
      }

      .reference-section {
        padding: 1.5rem;
      }

      .timeline::before {
        left: 15px;
      }

      .timeline-item {
        padding-left: 50px;
      }

      .timeline-item::before {
        left: 5px;
        width: 16px;
        height: 16px;
      }
    }
  </style>
</head>
<body>
  <!-- Sticky Navigation -->
  <nav class="sticky-nav">
    <ul>
      {days.map((day) => (
        <li>
          <button
            class="nav-btn"
            data-anchor={day.id}
            onclick={`document.getElementById('${day.id}').scrollIntoView({ behavior: 'smooth' }); updateActiveNav('${day.id}')`}
          >
            {day.label}
          </button>
        </li>
      ))}
      <li>
        <button
          class="nav-btn"
          data-anchor="info"
          onclick={`document.getElementById('info').scrollIntoView({ behavior: 'smooth' }); updateActiveNav('info')`}
        >
          Info
        </button>
      </li>
    </ul>
  </nav>

  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-emoji">🇳🇿</div>
    <h1>New Zealand Adventure</h1>
    <p class="hero-dates">April 27 – May 4, 2026</p>
    <p>8 friends, 8 days, unforgettable memories</p>
  </section>

  <!-- Main Container -->
  <div class="container">
    <!-- Day Sections -->
    {days.map((day) => (
      <section class="day-section" id={day.id}>
        <div class="day-header">
          <div class="day-meta">{day.date}</div>
          <h2>{day.title}</h2>
          {day.subtitle && <p class="day-subtitle">{day.subtitle}</p>}
        </div>

        <div class="timeline">
          {day.items.map((item) => (
            <div class={`timeline-item ${item.type}`}>
              <div class="timeline-content">
                {item.time && <div class="timeline-time">{item.time}</div>}
                <div class="timeline-title">{getTypeIcon(item.type)} {item.title}</div>
                {item.detail && <div class="timeline-detail">{item.detail}</div>}

                <div class="timeline-meta">
                  {item.cost && (
                    <span class="meta-badge">
                      💰 {item.cost}
                    </span>
                  )}
                  {item.mapsQuery && (
                    <a
                      href={generateMapsLink(item.mapsQuery)}
                      target="_blank"
                      rel="noopener"
                      class="btn-maps"
                    >
                      📍 Maps
                    </a>
                  )}
                  {item.link && (
                    <a href={item.link} target="_blank" rel="noopener">
                      🔗 Booking
                    </a>
                  )}
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>
    ))}

    <!-- Quick Reference Section -->
    <section class="reference-section" id="info">
      <h3>⚡ Quick Reference</h3>

      <!-- Hotels -->
      <h3 style="font-size: 1.1rem; margin-top: 1.5rem; border: none; color: #1f2937;">🏨 Accommodations</h3>
      <div class="hotels-grid">
        {hotels.map((hotel) => (
          <div class="hotel-card">
            <div class="hotel-name">{hotel.name}</div>
            <div class="hotel-detail">{hotel.address}</div>
            <div class="hotel-detail">📅 {hotel.dates}</div>
            <button
              class="btn-copy"
              onclick={`copyToClipboard('${hotel.address}')`}
            >
              📋 Copy Address
            </button>
            {hotel.link && (
              <a href={hotel.link} target="_blank" rel="noopener" class="btn-maps">
                🔗 Visit Website
              </a>
            )}
          </div>
        ))}
      </div>

      <!-- Emergency Contacts -->
      <h3 style="font-size: 1.1rem; margin-top: 1.5rem; border: none; color: #1f2937;">🚨 Emergency Contacts</h3>
      <div class="emergency-grid">
        {emergencyContacts.map((contact) => (
          <div class="emergency-item">
            <div class="emergency-label">{contact.label}</div>
            <div class="emergency-number">{contact.number}</div>
            {contact.detail && <div class="emergency-detail">{contact.detail}</div>}
          </div>
        ))}
      </div>

      <!-- NZ Phrases -->
      <h3 style="font-size: 1.1rem; margin-top: 1.5rem; border: none; color: #1f2937;">🗣️ Kia Ora: NZ Phrases</h3>
      <div class="phrases-grid">
        {nzPhrases.map((phrase) => (
          <div class="phrase-card">
            <div class="phrase-maori">{phrase.maori}</div>
            <div class="phrase-english">{phrase.english}</div>
          </div>
        ))}
      </div>
    </section>
  </div>

  <!-- Footer -->
  <footer>
    <p>Safe travels! 🧭 | Made for the crew, 2026</p>
  </footer>

  <script>
    function updateActiveNav(activeId) {
      document.querySelectorAll('.nav-btn').forEach((btn) => {
        btn.classList.remove('active');
      });
      const activeBtn = document.querySelector(`[data-anchor="${activeId}"]`);
      if (activeBtn) activeBtn.classList.add('active');
    }

    // Update active nav on scroll
    window.addEventListener('scroll', () => {
      const sections = document.querySelectorAll('[id]');
      let currentSection = '';

      sections.forEach((section) => {
        const sectionTop = section.offsetTop - 100;
        if (window.scrollY >= sectionTop) {
          currentSection = section.getAttribute('id');
        }
      });

      if (currentSection) {
        updateActiveNav(currentSection);
      }
    });

    // Set initial active
    updateActiveNav('apr27');
  </script>
</body>
</html>
