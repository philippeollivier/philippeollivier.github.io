<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>NZ Trip | Apr 27 – May 4, 2026</title>
  <style>
    /* Base styles */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen',
        'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue',
        sans-serif;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      color: #1f2937;
      background-color: #f9fafb;
    }

    body {
      line-height: 1.6;
      overflow: auto !important;
    }

    /* Dark mode support */
    @media (prefers-color-scheme: dark) {
      html {
        color: #f3f4f6;
        background-color: #111827;
      }
    }

    /* Typography */
    h1 {
      font-size: 2.5rem;
      font-weight: 800;
      letter-spacing: -0.025em;
      margin-bottom: 0.5rem;
    }

    h2 {
      font-size: 1.875rem;
      font-weight: 700;
      letter-spacing: -0.015em;
      margin-bottom: 0.75rem;
    }

    h3 {
      font-size: 1.25rem;
      font-weight: 600;
      margin-bottom: 0.5rem;
    }

    p, li {
      font-size: 1rem;
      line-height: 1.6;
    }

    /* Sticky Navigation */
    nav.sticky-nav {
      position: sticky;
      top: 0;
      z-index: 50;
      background: linear-gradient(to bottom, rgba(249, 250, 251, 0.95), rgba(249, 250, 251, 0.8));
      backdrop-filter: blur(10px);
      border-bottom: 2px solid #e5e7eb;
      padding: 0.75rem 0;
      overflow-x: auto;
      overflow-y: hidden;
      -webkit-overflow-scrolling: touch;
    }

    @media (prefers-color-scheme: dark) {
      nav.sticky-nav {
        background: linear-gradient(to bottom, rgba(17, 24, 39, 0.95), rgba(17, 24, 39, 0.8));
        border-bottom-color: #374151;
      }
    }

    nav.sticky-nav ul {
      display: flex;
      list-style: none;
      gap: 0.5rem;
      padding: 0 1rem;
      white-space: nowrap;
      min-width: 100%;
    }

    nav.sticky-nav button {
      padding: 0.5rem 1rem;
      font-size: 0.875rem;
      font-weight: 500;
      border: 2px solid #d1d5db;
      background: white;
      color: #1f2937;
      border-radius: 0.375rem;
      cursor: pointer;
      transition: all 0.2s ease;
      flex-shrink: 0;
    }

    @media (prefers-color-scheme: dark) {
      nav.sticky-nav button {
        background: #1f2937;
        color: #f3f4f6;
        border-color: #4b5563;
      }
    }

    nav.sticky-nav button:hover {
      border-color: #10b981;
      background-color: #ecfdf5;
      color: #059669;
    }

    @media (prefers-color-scheme: dark) {
      nav.sticky-nav button:hover {
        background-color: #064e3b;
      }
    }

    nav.sticky-nav button.active {
      border-color: #10b981;
      background: linear-gradient(135deg, #10b981 0%, #059669 100%);
      color: white;
      font-weight: 600;
    }

    /* Hero Section */
    .hero {
      background: linear-gradient(135deg, #065f46 0%, #047857 50%, #10b981 100%);
      color: white;
      padding: 3rem 1.5rem;
      text-align: center;
      border-bottom: 4px solid #059669;
    }

    .hero h1 {
      font-size: 3rem;
      margin-bottom: 0.5rem;
      text-shadow: 0 2px 4px rgba(0, 0, 0, 0.2);
    }

    .hero-dates {
      font-size: 1.125rem;
      margin-bottom: 1rem;
      opacity: 0.95;
    }

    .hero-emoji {
      font-size: 2.5rem;
      margin-bottom: 0.5rem;
    }

    /* Container */
    .container {
      max-width: 900px;
      margin: 0 auto;
      padding: 2rem 1rem;
    }

    /* Day sections */
    .day-section {
      margin-bottom: 3rem;
      scroll-margin-top: 80px;
    }

    .day-header {
      border-bottom: 3px solid #10b981;
      padding-bottom: 1rem;
      margin-bottom: 1.5rem;
    }

    .day-header h2 {
      margin-bottom: 0.25rem;
      color: #065f46;
    }

    @media (prefers-color-scheme: dark) {
      .day-header h2 {
        color: #6ee7b7;
      }
    }

    .day-meta {
      font-size: 0.875rem;
      color: #6b7280;
      margin-bottom: 0.5rem;
    }

    @media (prefers-color-scheme: dark) {
      .day-meta {
        color: #9ca3af;
      }
    }

    .day-subtitle {
      font-size: 1rem;
      color: #4b5563;
      font-weight: 500;
    }

    @media (prefers-color-scheme: dark) {
      .day-subtitle {
        color: #d1d5db;
      }
    }

    /* Timeline */
    .timeline {
      position: relative;
      padding-left: 0;
    }

    .timeline::before {
      content: '';
      position: absolute;
      left: 20px;
      top: 0;
      bottom: 0;
      width: 2px;
      background: linear-gradient(to bottom, #10b981, #d1d5db);
    }

    .timeline-item {
      position: relative;
      margin-bottom: 1.5rem;
      padding-left: 60px;
    }

    .timeline-item::before {
      content: '';
      position: absolute;
      left: 10px;
      top: 6px;
      width: 20px;
      height: 20px;
      border-radius: 50%;
      background: #10b981;
      border: 3px solid white;
      z-index: 2;
    }

    @media (prefers-color-scheme: dark) {
      .timeline-item::before {
        border-color: #111827;
      }
    }

    .timeline-item.flight::before {
      background: #3b82f6;
    }

    .timeline-item.transport::before {
      background: #6366f1;
    }

    .timeline-item.hike::before {
      background: #22c55e;
    }

    .timeline-item.hotel::before {
      background: #06b6d4;
    }

    .timeline-item.activity::before {
