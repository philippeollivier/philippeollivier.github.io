      { type: 'flight', time: 'Evening', title: 'Fly to Queenstown', detail: 'From Auckland (AKL) to Queenstown (ZQN)', cost: '$150 NZD per person', mapsQuery: 'Queenstown Airport, Queenstown, New Zealand' },
      { type: 'hotel', time: 'Night', title: 'Lylo Pod Hostel', detail: '36 Man Street, Queenstown 9300', cost: '$62 NZD per person', mapsQuery: 'Lylo Queenstown, 36 Man Street, Queenstown', link: 'https://www.lylo.com/queenstown/rooms-pods/pods-room/' }
