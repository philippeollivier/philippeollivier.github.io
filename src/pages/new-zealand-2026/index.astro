  flight: 'Flight', transport: 'Transport', hike: 'Hike',
  hotel: 'Stay', activity: 'Activity', meal: 'Food', info: 'Note',
};

function mapsUrl(query: string): string {
  return `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(query)}`;
}

function getLinkInfo(url: string): { label: string; type: 'alltrails' | 'external' } {
  if (url.includes('alltrails.com')) return { label: 'Open trail on AllTrails', type: 'alltrails' };
  if (url.includes('lylo.com')) return { label: 'Book on Lylo', type: 'external' };
  if (url.includes('tracknet.net')) return { label: 'Book on TrackNet', type: 'external' };
  if (url.includes('smallplanetsports')) return { label: 'Rent on Small Planet Sports', type: 'external' };
  if (url.includes('nzoneskydive')) return { label: 'Book on NZONE Skydive', type: 'external' };
  if (url.includes('doc.govt.nz')) return { label: 'View on DOC', type: 'external' };
  return { label: 'View details', type: 'external' };
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <meta name="theme-color" content="#0b3954">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <title>NZ 2026 | Apr 27 – May 4</title>
  <link rel="manifest" href="/new-zealand-2026/manifest.json">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,700;0,9..144,800;1,9..144,700;1,9..144,800&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    /* ===== TOKENS ===== */
    :root {
      --fiord: #0b3954;
      --bush: #1a5632;
      --pounamu: #3a8764;
      --tussock: #c9985a;
      --sunset: #c4655a;
      --glacier: #f7f6f3;
      --surface: #ffffff;
      --stone-900: #1c1917;
      --stone-600: #57534e;
      --stone-500: #78716c;
      --stone-400: #a8a29e;
      --stone-300: #d6d3d1;
      --stone-200: #e7e5e4;
      --stone-100: #f5f5f4;

      --cat-flight: #3b6b8c;
      --cat-transport: #5a8a70;
      --cat-hike: #2d6a4f;
      --cat-hotel: #7e6b9b;
      --cat-activity: #c9985a;
      --cat-meal: #c4655a;
      --cat-info: #8b8178;

      --font-display: 'Fraunces', serif;
      --font-body: 'Outfit', sans-serif;
      --radius: 12px;
      --radius-sm: 8px;
      --radius-pill: 999px;
      --shadow-sm: 0 1px 3px rgba(0,0,0,0.04), 0 1px 2px rgba(0,0,0,0.06);
      --shadow-md: 0 4px 6px rgba(0,0,0,0.05), 0 2px 4px rgba(0,0,0,0.06);
      --nav-h: 60px;
    }

    /* ===== RESET ===== */
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    html {
      scroll-behavior: smooth;
      -webkit-text-size-adjust: 100%;
    }

    body {
      font-family: var(--font-body);
      background: var(--glacier);
      color: var(--stone-900);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      overflow-x: hidden;
      padding-left: env(safe-area-inset-left);
      padding-right: env(safe-area-inset-right);
    }

    /* ===== TYPOGRAPHY ===== */
    h1, h2, h3 { font-family: var(--font-display); line-height: 1.15; }

    /* ===== HERO ===== */
    .hero {
      position: relative;
      min-height: 50svh;
      min-height: 50vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
      padding: 3rem 1.5rem 5rem;
      background: linear-gradient(150deg, var(--fiord) 0%, #0f4040 40%, var(--bush) 100%);
      background-size: 300% 300%;
      animation: heroShift 25s ease infinite;
      overflow: hidden;
      color: white;
    }

    @keyframes heroShift {
      0%, 100% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
    }

    .hero-content { position: relative; z-index: 2; max-width: 540px; }

    .hero-eyebrow {
      font-size: 0.8125rem;
      font-weight: 600;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      opacity: 0.8;
      margin-bottom: 1rem;
    }

    .hero h1 {
      font-size: clamp(2.75rem, 8vw, 4.5rem);
      font-weight: 800;
      letter-spacing: -0.03em;
      margin-bottom: 0.75rem;
      font-style: italic;
      text-shadow: 0 2px 20px rgba(0,0,0,0.15);
    }

    .hero-tagline {
      font-size: 1rem;
      font-weight: 300;
      opacity: 0.85;
      letter-spacing: 0.02em;
    }

    .hero-mountains {
      position: absolute;
      bottom: -1px;
      left: 0;
      width: 100%;
      height: 80px;
      z-index: 1;
    }

    /* ===== STATUS BAR ===== */
    .status-bar {
      text-align: center;
      padding: 0.625rem 1rem;
      font-size: 0.8125rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      color: var(--pounamu);
      background: rgba(58, 135, 100, 0.08);
      border-bottom: 1px solid rgba(58, 135, 100, 0.12);
    }

    /* ===== STICKY NAV ===== */
    .sticky-nav {
      position: sticky;
      top: 0;
      z-index: 50;
      background: rgba(247, 246, 243, 0.88);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-bottom: 1px solid rgba(0, 0, 0, 0.06);
      height: var(--nav-h);
      display: flex;
      align-items: center;
    }

    .nav-scroll {
      display: flex;
      gap: 0.5rem;
      overflow-x: auto;
      overflow-y: hidden;
      -webkit-overflow-scrolling: touch;
      padding: 0 1rem;
      scrollbar-width: none;
      width: 100%;
    }

    .nav-scroll::-webkit-scrollbar { display: none; }

    .nav-pill {
      flex-shrink: 0;
      display: inline-flex;
      align-items: center;
      padding: 0.4rem 0.9rem;
      border-radius: var(--radius-pill);
      font-size: 0.8125rem;
      font-weight: 500;
      font-family: var(--font-body);
      color: var(--stone-500);
      background: transparent;
      border: 1.5px solid transparent;
      cursor: pointer;
      transition: all 0.2s ease;
      white-space: nowrap;
      -webkit-tap-highlight-color: transparent;
    }

    .nav-pill:hover { color: var(--stone-900); background: rgba(0,0,0,0.04); }

    .nav-pill.active {
      color: white;
      background: var(--pounamu);
      border-color: var(--pounamu);
      box-shadow: 0 2px 8px rgba(58, 135, 100, 0.3);
    }

    .nav-pill--info {
      margin-left: auto;
      border: 1.5px solid var(--stone-300);
    }

    .nav-pill--info.active {
      border-color: var(--pounamu);
    }

    /* ===== MAIN CONTENT ===== */
    .content {
      max-width: 720px;
      margin: 0 auto;
      padding: 2rem 1.25rem 4rem;
    }

    /* ===== DAY SECTION ===== */
    .day-section {
      margin-bottom: 3rem;
      scroll-margin-top: calc(var(--nav-h) + 16px);
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.5s ease, transform 0.5s ease;
    }

    .day-section.visible {
      opacity: 1;
      transform: translateY(0);
    }

    .day-header {
      position: relative;
      margin-bottom: 1.5rem;
      padding-bottom: 1.25rem;
      border-bottom: 2px solid var(--stone-200);
    }

    .day-watermark {
      position: absolute;
      top: -0.75rem;
      right: 0;
      font-family: var(--font-display);
      font-size: 6rem;
      font-weight: 800;
      line-height: 1;
      color: rgba(0, 0, 0, 0.03);
      pointer-events: none;
      user-select: none;
    }

    .day-date {
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--pounamu);
      margin-bottom: 0.375rem;
    }

    .day-title {
      font-size: 1.75rem;
      font-weight: 700;
      color: var(--stone-900);
      letter-spacing: -0.02em;
      margin-bottom: 0.25rem;
    }

    .day-subtitle {
      font-size: 0.9375rem;
      color: var(--stone-500);
      font-weight: 400;
    }

    /* ===== TIMELINE ===== */
    .timeline {
      position: relative;
    }

    .timeline::before {
      content: '';
      position: absolute;
      left: calc(5.5rem + 0.5rem + 7px);
      top: 4px;
      bottom: 4px;
      width: 2px;
      background: linear-gradient(to bottom, var(--stone-300), var(--stone-200));
      border-radius: 1px;
    }

    /* ===== TIMELINE EVENT ===== */
    .timeline-event {
      display: grid;
      grid-template-columns: 5.5rem 16px 1fr;
      column-gap: 0.5rem;
      align-items: start;
      margin-bottom: 1rem;
    }

    .timeline-event:last-child { margin-bottom: 0; }

    .event-time {
      grid-column: 1;
      text-align: right;
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--stone-500);
      padding-top: 1rem;
      line-height: 1.2;
      overflow: hidden;
    }

    .timeline-dot {
      grid-column: 2;
      width: 16px;
      height: 16px;
      border-radius: 50%;
      background: var(--dot-color, var(--pounamu));
      border: 3px solid var(--glacier);
      z-index: 2;
      margin-top: 0.9375rem;
      justify-self: center;
      transition: transform 0.2s ease;
    }

    .timeline-event:hover .timeline-dot {
      transform: scale(1.2);
    }

    /* ===== EVENT CARD ===== */
    .event-card {
      grid-column: 3;
      background: var(--surface);
      border: 1px solid var(--stone-200);
      border-radius: var(--radius);
      padding: 1rem 1.125rem;
      border-left: 4px solid var(--accent-color, var(--pounamu));
      box-shadow: var(--shadow-sm);
      transition: box-shadow 0.2s ease, transform 0.2s ease;
    }

    .event-card:hover {
      box-shadow: var(--shadow-md);
      transform: translateY(-1px);
    }

    .event-title-row {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 0.5rem;
      margin-bottom: 0.25rem;
    }

    .type-badge {
      flex-shrink: 0;
      display: inline-flex;
      align-items: center;
      gap: 0.25rem;
      padding: 0.2rem 0.6rem;
      border-radius: var(--radius-pill);
      font-size: 0.6875rem;
      font-weight: 600;
      letter-spacing: 0.03em;
      text-transform: uppercase;
      color: white;
      background: var(--badge-color, var(--pounamu));
      margin-top: 0.125rem;
    }

    a.type-badge--link {
      text-decoration: none;
      color: white;
      transition: opacity 0.15s ease;
    }
    a.type-badge--link:hover {
      opacity: 0.85;
    }

    .event-title {
      font-family: var(--font-display);
      font-size: 1.0625rem;
      font-weight: 600;
      color: var(--stone-900);
      line-height: 1.3;
      min-width: 0;
    }

    .event-detail {
      font-size: 0.875rem;
      color: var(--stone-500);
      line-height: 1.5;
    }

    .event-actions {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.25rem;
      margin-top: 0.75rem;
    }

    .event-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 0.375rem;
    }

    .cost-pill {
      display: inline-flex;
      align-items: center;
      gap: 0.25rem;
      padding: 0.3rem 0.7rem;
      background: rgba(201, 152, 90, 0.1);
      color: #8b6914;
      border-radius: var(--radius-pill);
      font-size: 0.8125rem;
      font-weight: 600;
    }

    .distance-pill {
      display: inline-flex;
      align-items: center;
      gap: 0.25rem;
      padding: 0.3rem 0.7rem;
      background: rgba(45, 106, 79, 0.1);
      color: #1e6040;
      border-radius: var(--radius-pill);
      font-size: 0.8125rem;
      font-weight: 600;
    }

    .action-link {
      display: inline-flex;
      align-items: center;
      gap: 0.375rem;
      font-size: 0.8125rem;
      font-weight: 600;
      text-decoration: none;
      cursor: pointer;
      border: none;
      background: none;
      font-family: var(--font-body);
      min-height: 36px;
      transition: opacity 0.15s ease;
      -webkit-tap-highlight-color: transparent;
      padding: 0.25rem 0;
    }

    .action-link:hover { opacity: 0.75; }

    .action-link svg { flex-shrink: 0; }

    .action-link--maps { color: #1a73e8; }
    .action-link--alltrails { color: #428813; }
    .action-link--flight { color: #0369a1; }
    .action-link--external { color: var(--stone-500); }

    .action-link--maps:hover, .action-link--alltrails:hover, .action-link--flight:hover, .action-link--external:hover {
      text-decoration: underline;
    }

    /* Keep .action-btn for copy button in hotel cards */
    .action-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      padding: 0.4rem 0.85rem;
      border-radius: var(--radius-sm);
      font-size: 0.8125rem;
      font-weight: 600;
      text-decoration: none;
      cursor: pointer;
      border: none;
      font-family: var(--font-body);
      min-height: 36px;
      transition: all 0.15s ease;
      -webkit-tap-highlight-color: transparent;
    }

    /* ===== QUICK REFERENCE ===== */
    .ref-section {
      scroll-margin-top: calc(var(--nav-h) + 16px);
      margin-top: 2rem;
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.5s ease, transform 0.5s ease;
    }

    .ref-section.visible {
      opacity: 1;
      transform: translateY(0);
    }

    .ref-heading {
      font-size: 2rem;
      font-weight: 700;
      color: var(--stone-900);
      letter-spacing: -0.02em;
      margin-bottom: 2rem;
      padding-bottom: 1rem;
      border-bottom: 2px solid var(--pounamu);
    }

    .ref-group {
      margin-bottom: 2.5rem;
    }

    .ref-group:last-child { margin-bottom: 0; }

    .ref-group-title {
      font-family: var(--font-display);
      font-size: 1.25rem;
      font-weight: 600;
      color: var(--stone-900);
      margin-bottom: 1rem;
    }

    /* Hotel cards */
    .hotel-card {
      background: var(--surface);
      border: 1px solid var(--stone-200);
      border-radius: var(--radius);
      padding: 1.25rem;
      margin-bottom: 0.75rem;
      box-shadow: var(--shadow-sm);
    }

    .hotel-name {
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 1.125rem;
      color: var(--stone-900);
      margin-bottom: 0.5rem;
    }

    .hotel-meta {
      font-size: 0.875rem;
      color: var(--stone-500);
      margin-bottom: 0.25rem;
    }

    .hotel-address {
      font-size: 0.9375rem;
      font-weight: 500;
      color: var(--stone-600);
      background: var(--stone-100);
      padding: 0.625rem 0.875rem;
      border-radius: var(--radius-sm);
      margin: 0.75rem 0;
      border: 1px solid var(--stone-200);
    }

    .hotel-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-top: 0.75rem;
    }

    .copy-btn {
      background: var(--fiord);
      color: white;
    }

    .copy-btn:hover { background: #093047; }

    .copy-btn.copied {
      background: var(--pounamu);
    }

    /* Emergency cards */
    .emergency-card {
      background: linear-gradient(135deg, #fef2f2, #fef7f7);
      border: 1px solid #fecaca;
      border-radius: var(--radius);
      padding: 1.25rem;
      margin-bottom: 0.75rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
    }

    .emergency-info { flex: 1; }

    .emergency-label {
      font-weight: 600;
      font-size: 0.9375rem;
      color: var(--stone-900);
      margin-bottom: 0.125rem;
    }

    .emergency-detail {
      font-size: 0.8125rem;
      color: var(--stone-500);
    }

    .emergency-number {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
      font-weight: 700;
      font-family: var(--font-body);
      color: var(--sunset);
      background: white;
      padding: 0.5rem 1rem;
      border-radius: var(--radius-sm);
      text-decoration: none;
      border: 2px solid #fecaca;
      min-width: 80px;
      text-align: center;
      transition: all 0.15s ease;
      -webkit-tap-highlight-color: transparent;
    }

    .emergency-number:hover {
      background: var(--sunset);
      color: white;
      border-color: var(--sunset);
    }

    /* Phrase grid */
    .phrase-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 0.625rem;
    }

    .phrase-card {
      background: var(--surface);
      border: 1px solid var(--stone-200);
      border-radius: var(--radius-sm);
      padding: 0.875rem 1rem;
      transition: all 0.2s ease;
    }

    .phrase-card:hover {
      border-color: var(--pounamu);
      box-shadow: var(--shadow-sm);
    }

    .phrase-card.maori { border-left: 3px solid var(--pounamu); }

    .phrase-term {
      font-weight: 700;
      font-size: 1rem;
      color: var(--stone-900);
      margin-bottom: 0.125rem;
    }

    .phrase-meaning {
      font-size: 0.8125rem;
      color: var(--stone-500);
    }

    /* Budget table */
    .budget-table {
      width: 100%;
      border-collapse: collapse;
    }

    .budget-table tr {
      border-bottom: 1px solid var(--stone-200);
    }

    .budget-table tr:last-child { border-bottom: none; }

    .budget-table td {
      padding: 0.75rem 0;
      font-size: 0.9375rem;
    }

    .budget-table td:first-child { color: var(--stone-600); }
    .budget-table td:last-child { text-align: right; font-weight: 600; color: var(--stone-900); }

    .budget-total {
      margin-top: 1rem;
      padding: 1rem 1.25rem;
      background: rgba(58, 135, 100, 0.06);
      border: 1px solid rgba(58, 135, 100, 0.15);
      border-radius: var(--radius-sm);
      display: flex;
      justify-content: space-between;
      align-items: baseline;
    }

    .budget-total-label {
      font-size: 0.9375rem;
      font-weight: 600;
      color: var(--stone-600);
    }

    .budget-total-amount {
      font-family: var(--font-display);
      font-size: 1.375rem;
      font-weight: 700;
      color: var(--pounamu);
    }

    .budget-note {
      font-size: 0.8125rem;
      color: var(--stone-400);
      margin-top: 0.5rem;
    }

    /* ===== NO-SIGNAL BANNER ===== */
    .no-signal-banner {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.625rem 0.875rem;
      background: rgba(201, 152, 90, 0.1);
      border: 1px solid rgba(201, 152, 90, 0.25);
      border-radius: var(--radius-sm);
      font-size: 0.8125rem;
      font-weight: 500;
      color: #8b6914;
      margin-bottom: 1rem;
    }

    .no-signal-banner svg { flex-shrink: 0; }

    /* ===== UP NEXT HIGHLIGHT ===== */
    .event-card.up-next {
      border-color: var(--pounamu);
      box-shadow: 0 0 0 2px rgba(58, 135, 100, 0.15), var(--shadow-md);
      position: relative;
    }

    .up-next-label {
      display: inline-flex;
      align-items: center;
      gap: 0.25rem;
      position: absolute;
      top: -0.625rem;
      right: 0.75rem;
      padding: 0.125rem 0.5rem;
      background: var(--pounamu);
      color: white;
      font-size: 0.625rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      border-radius: var(--radius-pill);
    }

    /* ===== COLLAPSIBLE PAST DAYS ===== */
    .day-section.collapsed .timeline {
      display: none;
    }

    .day-section.collapsed .day-header {
      cursor: pointer;
      margin-bottom: 0;
      padding-bottom: 0;
      border-bottom-color: transparent;
      opacity: 0.5;
      transition: opacity 0.2s ease;
    }

    .day-section.collapsed .day-header:hover {
      opacity: 0.75;
    }

    .day-expand-hint {
      display: none;
      font-size: 0.75rem;
      color: var(--stone-400);
      font-weight: 500;
      margin-top: 0.25rem;
    }

    .day-section.collapsed .day-expand-hint {
      display: block;
    }

    /* ===== FOOTER ===== */
    .footer {
      text-align: center;
      padding: 2.5rem 1.5rem;
      color: var(--stone-400);
      font-size: 0.875rem;
      border-top: 1px solid var(--stone-200);
      margin-top: 2rem;
    }

    .footer-text {
      font-family: var(--font-display);
      font-style: italic;
      font-size: 1.125rem;
      color: var(--stone-500);
      margin-bottom: 0.5rem;
    }

    /* ===== TOAST ===== */
    .toast {
      position: fixed;
      bottom: 2rem;
      left: 50%;
      transform: translateX(-50%) translateY(80px);
      background: var(--stone-900);
      color: white;
      padding: 0.75rem 1.5rem;
      border-radius: var(--radius-pill);
      font-size: 0.875rem;
      font-weight: 500;
      opacity: 0;
      transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
      z-index: 100;
      pointer-events: none;
      box-shadow: 0 8px 24px rgba(0,0,0,0.15);
    }

    .toast.show {
      transform: translateX(-50%) translateY(0);
      opacity: 1;
    }

    /* ===== ANIMATIONS ===== */
    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        transition-duration: 0.01ms !important;
      }
      .hero { animation: none; }
    }

    /* ===== RESPONSIVE ===== */
    @media (max-width: 480px) {
      .hero { min-height: 42svh; min-height: 42vh; padding: 2.5rem 1.25rem 4rem; }
      .hero h1 { font-size: 2.5rem; }
      .content { padding: 1.5rem 1rem 3rem; }
      .day-watermark { font-size: 4.5rem; }
      .day-title { font-size: 1.5rem; }
      .timeline-event { grid-template-columns: 4.5rem 12px 1fr; column-gap: 0.375rem; }
      .timeline::before { left: calc(4.5rem + 0.375rem + 5px); }
      .timeline-dot { width: 12px; height: 12px; margin-top: 1rem; }
      .event-time { font-size: 0.6875rem; padding-top: 0.9375rem; }
      .event-card { padding: 0.875rem 1rem; }
      .phrase-grid { grid-template-columns: 1fr 1fr; }
      .ref-heading { font-size: 1.625rem; }
      .emergency-card { flex-direction: column; align-items: stretch; }
      .emergency-number { width: 100%; }
    }

    @media (min-width: 768px) {
      .content { padding: 3rem 2rem 5rem; }
      .nav-scroll { padding: 0 2rem; justify-content: center; }
      .phrase-grid { grid-template-columns: repeat(3, 1fr); }
    }
  </style>
</head>
<body>
  <!-- Toast -->
  <div class="toast" id="toast">Copied to clipboard</div>

  <!-- Hero -->
  <header class="hero">
    <div class="hero-content">
      <p class="hero-eyebrow">April 27 – May 4, 2026</p>
      <h1>New Zealand</h1>
      <p class="hero-tagline">Kia ora! - Mad Maggie</p>
    </div>
    <svg class="hero-mountains" viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,80 L0,52 Q120,35 240,45 Q360,55 480,30 Q600,5 720,28 Q840,50 960,22 Q1080,0 1200,32 Q1320,55 1440,38 L1440,80 Z" fill="#f7f6f3"/>
    </svg>
  </header>

  <!-- Status Bar -->
  <div class="status-bar" id="status-bar"></div>

  <!-- Sticky Nav -->
  <nav class="sticky-nav">
    <div class="nav-scroll" id="nav-scroll">
      {days.map((day) => (
        <button
          class="nav-pill"
          data-target={day.id}
        >
          {day.label}
        </button>
      ))}
      <button class="nav-pill nav-pill--info" data-target="info">
        Quick Ref
      </button>
    </div>
  </nav>

  <!-- Main Content -->
  <main class="content">
    {days.map((day) => (
      <section class="day-section" id={day.id} data-date={day.id}>
        <div class="day-header">
          <span class="day-watermark">{day.dayNum}</span>
          <div class="day-date">{day.date}</div>
          <h2 class="day-title">{day.title}</h2>
          {day.subtitle && <p class="day-subtitle">{day.subtitle}</p>}
          <p class="day-expand-hint">Tap to expand</p>
        </div>
        {day.noSignal && (
          <div class="no-signal-banner">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="1" y1="1" x2="23" y2="23"/><path d="M16.72 11.06A10.94 10.94 0 0 1 19 12.55"/><path d="M5 12.55a10.94 10.94 0 0 1 5.17-2.39"/><path d="M10.71 5.05A16 16 0 0 1 22.56 9"/><path d="M1.42 9a15.91 15.91 0 0 1 4.7-2.88"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><line x1="12" y1="20" x2="12.01" y2="20"/></svg>
            <span>No cell service on the track — download offline maps beforehand</span>
          </div>
        )}
        <div class="timeline">
          {day.items.map((item) => (
            <div class="timeline-event" style={`--dot-color: var(--cat-${item.type}); --accent-color: var(--cat-${item.type}); --badge-color: var(--cat-${item.type});`}>
              {item.time ? <span class="event-time">{item.time}</span> : <span></span>}
              <div class="timeline-dot"></div>
              <div class="event-card">
                <div class="event-title-row">
                  <h3 class="event-title">{item.title}</h3>
                  {item.flightCodes && item.flightCodes.length > 0 ? (
                    item.flightCodes.map((code) => (
                      <a href={`https://www.google.com/search?q=${code}+flight+status`} target="_blank" rel="noopener noreferrer" class="type-badge type-badge--link">{typeIcons[item.type]} {code}</a>
                    ))
                  ) : (
                    <span class="type-badge">{typeIcons[item.type]} {typeLabels[item.type]}</span>
                  )}
                </div>
                {item.detail && <p class="event-detail">{item.detail}</p>}
                {(item.cost || item.distance || item.mapsQuery || item.link) && (
                  <div class="event-actions">
                    {(item.cost || item.distance) && (
                      <div class="event-pills">
                        {item.cost && <span class="cost-pill">{item.cost}</span>}
                        {item.distance && <span class="distance-pill">{item.distance}</span>}
                      </div>
                    )}
                    {item.mapsQuery && (
                      <a href={mapsUrl(item.mapsQuery)} target="_blank" rel="noopener noreferrer" class="action-link action-link--maps">
                        <svg width="16" height="16" viewBox="0 0 92.3 132.3" xmlns="http://www.w3.org/2000/svg"><path fill="#1a73e8" d="M60.2 2.2C55.8.8 51 0 46.1 0 32 0 19.3 6.4 10.8 16.5l21.8 18.3L60.2 2.2z"/><path fill="#ea4335" d="M10.8 16.5C4.1 24.5 0 34.9 0 46.1c0 8.7 1.7 15.7 4.6 22l28-33.3-21.8-18.3z"/><path fill="#4285f4" d="M46.2 28.5c9.8 0 17.7 7.9 17.7 17.7 0 4.3-1.6 8.3-4.2 11.4 0 0 13.9-16.6 27.5-32.7-5.6-10.8-15.3-19-27-22.7L32.6 34.8c3.3-3.8 8.1-6.3 13.6-6.3"/><path fill="#fbbc04" d="M46.2 63.8c-9.8 0-17.7-7.9-17.7-17.7 0-4.3 1.5-8.3 4.1-11.3l-28 33.3c4.8 10.6 12.8 19.2 21 29.9l34.1-40.5c-3.3 3.9-8.1 6.3-13.5 6.3"/><path fill="#34a853" d="M59.1 109.2c15.4-24.1 33.3-35 33.3-63.1 0-9.1-2.4-17.2-6.5-24.3L25.6 98c2.6 3.4 5.3 7.3 7.9 11.3 9.4 14.5 6.8 23.1 12.8 23.1s3.4-8.7 12.8-23.2"/></svg>
                        <span>Open in Google Maps</span>
                      </a>
                    )}
                    {item.link && (
                      getLinkInfo(item.link).type === 'alltrails' ? (
                        <a href={item.link} target="_blank" rel="noopener noreferrer" class="action-link action-link--alltrails">
                          <svg width="16" height="16" viewBox="0 0 24 24" fill="#428813" xmlns="http://www.w3.org/2000/svg"><path d="M10.5 3.5L7 9.5l2.5 3.5-1.5 2C6.5 12.5 4 9 4 9L0 16h10l2-3 2 3h10l-4-7-3.5 5-2.5-3.5 3.5-5L14 0l-3.5 3.5z" transform="translate(0 4) scale(1)"/></svg>
                          <span>{getLinkInfo(item.link).label}</span>
                        </a>
                      ) : (
                        <a href={item.link} target="_blank" rel="noopener noreferrer" class="action-link action-link--external">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                          <span>{getLinkInfo(item.link).label}</span>
                        </a>
                      )
                    )}
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </section>
    ))}

    <!-- Quick Reference -->
    <section class="ref-section" id="info">
      <h2 class="ref-heading">Quick Reference</h2>

      <!-- Hotels -->
      <div class="ref-group">
        <h3 class="ref-group-title">Accommodations</h3>
        {hotels.map((hotel) => (
          <div class="hotel-card">
            <div class="hotel-name">{hotel.name}</div>
            <div class="hotel-meta">{hotel.dates}</div>
            <div class="hotel-address">{hotel.address}</div>
            <div class="hotel-actions">
              {hotel.address !== 'To be confirmed' && (
                <button class="action-btn copy-btn" data-copy={hotel.address}>
                  Copy Address
                </button>
              )}
              <a href={mapsUrl(hotel.mapsQuery)} target="_blank" rel="noopener noreferrer" class="action-link action-link--maps">
                <svg width="16" height="16" viewBox="0 0 92.3 132.3" xmlns="http://www.w3.org/2000/svg"><path fill="#1a73e8" d="M60.2 2.2C55.8.8 51 0 46.1 0 32 0 19.3 6.4 10.8 16.5l21.8 18.3L60.2 2.2z"/><path fill="#ea4335" d="M10.8 16.5C4.1 24.5 0 34.9 0 46.1c0 8.7 1.7 15.7 4.6 22l28-33.3-21.8-18.3z"/><path fill="#4285f4" d="M46.2 28.5c9.8 0 17.7 7.9 17.7 17.7 0 4.3-1.6 8.3-4.2 11.4 0 0 13.9-16.6 27.5-32.7-5.6-10.8-15.3-19-27-22.7L32.6 34.8c3.3-3.8 8.1-6.3 13.6-6.3"/><path fill="#fbbc04" d="M46.2 63.8c-9.8 0-17.7-7.9-17.7-17.7 0-4.3 1.5-8.3 4.1-11.3l-28 33.3c4.8 10.6 12.8 19.2 21 29.9l34.1-40.5c-3.3 3.9-8.1 6.3-13.5 6.3"/><path fill="#34a853" d="M59.1 109.2c15.4-24.1 33.3-35 33.3-63.1 0-9.1-2.4-17.2-6.5-24.3L25.6 98c2.6 3.4 5.3 7.3 7.9 11.3 9.4 14.5 6.8 23.1 12.8 23.1s3.4-8.7 12.8-23.2"/></svg>
                <span>Open in Google Maps</span>
              </a>
              {hotel.link && (
                <a href={hotel.link} target="_blank" rel="noopener noreferrer" class="action-link action-link--external">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                  <span>{getLinkInfo(hotel.link).label}</span>
                </a>
              )}
            </div>
          </div>
        ))}
      </div>

      <!-- Emergency -->
      <div class="ref-group">
        <h3 class="ref-group-title">Emergency Numbers</h3>
        {emergencyContacts.map((c) => (
          <div class="emergency-card">
            <div class="emergency-info">
              <div class="emergency-label">{c.label}</div>
              {c.detail && <div class="emergency-detail">{c.detail}</div>}
            </div>
            <a href={`tel:${c.number.replace(/\s/g, '')}`} class="emergency-number">{c.number}</a>
          </div>
        ))}
      </div>

      <!-- Phrases -->
      <div class="ref-group">
        <h3 class="ref-group-title">Te Reo Maori & NZ Slang</h3>
        <div class="phrase-grid">
          {phrases.map((p) => (
            <div class={`phrase-card${p.isMaori ? ' maori' : ''}`}>
              <div class="phrase-term">{p.term}</div>
              <div class="phrase-meaning">{p.meaning}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Budget -->
      <div class="ref-group">
        <h3 class="ref-group-title">Trip Budget (per person)</h3>
        <p style="font-size: 0.8125rem; color: var(--stone-400); margin-bottom: 0.75rem;">1 NZD ≈ 0.60 USD</p>
        <table class="budget-table">
          <thead>
            <tr style="border-bottom: 2px solid var(--stone-200);">
              <td style="font-weight: 600; color: var(--stone-900); font-size: 0.8125rem;"></td>
              <td style="text-align: right; font-weight: 600; color: var(--stone-900); font-size: 0.75rem;">NZD</td>
              <td style="text-align: right; font-weight: 600; color: var(--stone-400); font-size: 0.75rem;">USD</td>
            </tr>
          </thead>
          <tbody>
          {costs.map((c) => (
            <tr>
              <td>{c.label}</td>
              <td>{c.amount}</td>
              <td style="text-align: right; color: var(--stone-400); font-weight: 500;">{c.usd}</td>
            </tr>
          ))}
          </tbody>
        </table>
        <div class="budget-total">
          <span class="budget-total-label">Estimated Total</span>
          <span class="budget-total-amount">~$1,200–1,400 <span style="font-size: 0.8125rem; font-weight: 500; color: var(--stone-500);">NZD</span></span>
        </div>
        <p class="budget-note">≈ $720–840 USD · Excludes May 1 accommodation (TBD) and meals</p>
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer class="footer">
    <p class="footer-text">Haere ra — safe travels, whanau</p>
    <p>If anything on this page is incorrect, kihi taku kaihe</p>
  </footer>

  <!-- Scripts -->
  <script>
    // === Date helpers (NZ timezone) ===
    var DAY_IDS = ['apr27','apr28','apr29','apr30','may1','may2','may3','may4'];
    var DAY_DATES = [27,28,29,30,1,2,3,4]; // day of month
    var DAY_MONTHS = [3,3,3,3,4,4,4,4]; // 0-indexed months (3=Apr, 4=May)

    function getNZDate() {
      // Get current time in NZ (UTC+12)
      var now = new Date();
      var nz = new Date(now.getTime() + (now.getTimezoneOffset() + 720) * 60000);
      return nz;
    }

    function getTripDayIndex() {
      var nz = getNZDate();
      var m = nz.getMonth();
      var d = nz.getDate();
      for (var i = 0; i < DAY_IDS.length; i++) {
        if (m === DAY_MONTHS[i] && d === DAY_DATES[i]) return i;
      }
      // Before trip
      if (m < 3 || (m === 3 && d < 27)) return -1;
      // After trip
      return 8;
    }

    // === Trip Status ===
    (function() {
      var statusEl = document.getElementById('status-bar');
      if (!statusEl) return;
      var start = new Date('2026-04-27T00:00:00+12:00');
      var end = new Date('2026-05-04T23:59:59+12:00');
      var now = new Date();
      if (now < start) {
        var diff = Math.ceil((start.getTime() - now.getTime()) / 86400000);
        statusEl.textContent = diff === 1
          ? 'Tomorrow you fly!'
          : diff + ' days until departure';
      } else if (now <= end) {
        var dayNum = Math.min(Math.floor((now.getTime() - start.getTime()) / 86400000) + 1, 8);
        statusEl.textContent = 'Day ' + dayNum + ' of 8';
      } else {
        statusEl.textContent = 'Trip complete — what an adventure!';
      }
    })();

    // === Collapsible Past Days ===
    (function() {
      var idx = getTripDayIndex();
      // Only collapse if we're during or after the trip
      if (idx <= 0) return;
      for (var i = 0; i < Math.min(idx, DAY_IDS.length); i++) {
        var section = document.getElementById(DAY_IDS[i]);
        if (section) {
          section.classList.add('collapsed');
          // Make header clickable to expand/collapse
          var header = section.querySelector('.day-header');
          if (header) {
            header.addEventListener('click', (function(sec) {
              return function() { sec.classList.toggle('collapsed'); };
            })(section));
          }
        }
      }
    })();

    // === Auto-scroll to Today ===
    (function() {
      var idx = getTripDayIndex();
      if (idx >= 0 && idx < DAY_IDS.length) {
        // Delay slightly so layout is settled
        setTimeout(function() {
          var target = document.getElementById(DAY_IDS[idx]);
          if (target) target.scrollIntoView({ behavior: 'auto' });
        }, 100);
      }
    })();

    // === Up Next Highlight ===
    (function() {
      var idx = getTripDayIndex();
      if (idx < 0 || idx >= DAY_IDS.length) return;
      var section = document.getElementById(DAY_IDS[idx]);
      if (!section) return;
      // Find the first event card in today's section
      var cards = section.querySelectorAll('.event-card');
      var nz = getNZDate();
      var hours = nz.getHours();
      var found = false;

      for (var i = 0; i < cards.length; i++) {
        var timeEl = cards[i].closest('.timeline-event')?.querySelector('.event-time');
        if (!timeEl) continue;
        var text = timeEl.textContent.trim();
        // Parse start hour from time text
        var match = text.match(/(\d{1,2}):(\d{2})\s*(AM|PM)/i);
        if (match) {
          var h = parseInt(match[1]);
          var ampm = match[3].toUpperCase();
          if (ampm === 'PM' && h !== 12) h += 12;
          if (ampm === 'AM' && h === 12) h = 0;
          if (h >= hours) {
            cards[i].classList.add('up-next');
            var label = document.createElement('span');
            label.className = 'up-next-label';
            label.textContent = 'Up next';
            cards[i].appendChild(label);
            found = true;
            break;
          }
        }
      }
      // If no future timed event found, highlight the first card
      if (!found && cards.length > 0) {
        cards[0].classList.add('up-next');
        var label = document.createElement('span');
        label.className = 'up-next-label';
        label.textContent = 'Up next';
        cards[0].appendChild(label);
      }
    })();

    // === Navigation ===
    (function() {
      var pills = document.querySelectorAll('.nav-pill');
      var sections = [];

      pills.forEach(function(pill) {
        var targetId = pill.getAttribute('data-target');
        var target = document.getElementById(targetId);
        if (target) sections.push({ id: targetId, el: target, pill: pill });

        pill.addEventListener('click', function() {
          // Expand section if collapsed
          if (target && target.classList.contains('collapsed')) {
            target.classList.remove('collapsed');
          }
          if (target) {
            target.scrollIntoView({ behavior: 'smooth' });
          }
        });
      });

      function setActive(id) {
        pills.forEach(function(p) { p.classList.remove('active'); });
        var activePill = document.querySelector('[data-target="' + id + '"]');
        if (activePill) {
          activePill.classList.add('active');
          activePill.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
        }
      }

      var ticking = false;
      window.addEventListener('scroll', function() {
        if (!ticking) {
          requestAnimationFrame(function() {
            var current = '';
            var navH = 80;
            for (var i = 0; i < sections.length; i++) {
              var rect = sections[i].el.getBoundingClientRect();
              if (rect.top <= navH + 20) {
                current = sections[i].id;
              }
            }
            if (current) setActive(current);
            ticking = false;
          });
          ticking = true;
        }
      });

      if (sections.length > 0) setActive(sections[0].id);
    })();

    // === Scroll Reveal ===
    (function() {
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

      document.querySelectorAll('.day-section, .ref-section').forEach(function(el) {
        observer.observe(el);
      });
    })();

    // === Copy to Clipboard ===
    (function() {
      var toast = document.getElementById('toast');
      var toastTimer;

      function showToast(msg) {
        toast.textContent = msg || 'Copied to clipboard';
        toast.classList.add('show');
        clearTimeout(toastTimer);
        toastTimer = setTimeout(function() {
          toast.classList.remove('show');
        }, 2000);
      }

      document.querySelectorAll('.copy-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var text = btn.getAttribute('data-copy');
          if (!text) return;
          navigator.clipboard.writeText(text).then(function() {
            btn.textContent = 'Copied!';
            btn.classList.add('copied');
            showToast('Address copied — show to taxi driver');
            setTimeout(function() {
              btn.textContent = 'Copy Address';
              btn.classList.remove('copied');
            }, 2500);
          });
        });
      });
    })();

    // === Register Service Worker ===
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('/new-zealand-2026/sw.js').catch(function() {});
    }
  </script>
</body>
</html>
